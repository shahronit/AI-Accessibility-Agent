# --- LLM: pick one or combine (see README for auto order) ---
# LLM_PROVIDER=gemini | anthropic | assemblyai  (optional; forces one backend)

# Google Gemini (free tier in AI Studio) — good default for Explain + Chat
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model ids: https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
GEMINI_MODEL_CRITICAL=gemini-2.5-flash
# Comma-separated extras if the primary hits 429 / separate free-tier buckets:
# GEMINI_MODEL_FALLBACKS=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-1.5-flash
# Retries per model on 429 (default 4)
# GEMINI_429_ATTEMPTS_PER_MODEL=4
# If ANTHROPIC_API_KEY is set, use Claude when Gemini is still rate-limited after retries (default on)
# GEMINI_FALLBACK_TO_ANTHROPIC=false

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL_SONNET=claude-sonnet-4-5
# ANTHROPIC_MODEL_OPUS=claude-opus-4-6

# AssemblyAI LLM Gateway (plan may require LeMUR/LLM)
# https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=

# Optional: US default is https://llm-gateway.assemblyai.com/v1/chat/completions
# EU: https://llm-gateway.eu.assemblyai.com/v1/chat/completions
# ASSEMBLYAI_LLM_URL=

ASSEMBLYAI_MODEL_DEFAULT=claude-sonnet-4-5-20250929
ASSEMBLYAI_MODEL_CRITICAL=claude-opus-4-6

# Local development: path to Chrome/Chromium binary for accessibility scans
# macOS example:
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
PUPPETEER_EXECUTABLE_PATH=
