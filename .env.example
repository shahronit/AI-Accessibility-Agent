# --- LLM: pick one or combine (see README for auto order) ---
# LLM_PROVIDER=gemini | anthropic | assemblyai  (optional; forces one backend)

# Google Gemini (free tier in AI Studio) — good default for Explain + Chat
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model ids: https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
GEMINI_MODEL_CRITICAL=gemini-2.5-flash
# Comma-separated extras if the primary hits 429 / separate free-tier buckets:
# GEMINI_MODEL_FALLBACKS=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-1.5-flash
# Retries per model on 429 (default 4)
# GEMINI_429_ATTEMPTS_PER_MODEL=4
# If ANTHROPIC_API_KEY is set, use Claude when Gemini is still rate-limited after retries (default on)
# GEMINI_FALLBACK_TO_ANTHROPIC=false

# Anthropic — https://console.anthropic.com/
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL_SONNET=claude-sonnet-4-5
# ANTHROPIC_MODEL_OPUS=claude-opus-4-6

# AssemblyAI LLM Gateway (plan may require LeMUR/LLM)
# https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=

# Optional: US default is https://llm-gateway.assemblyai.com/v1/chat/completions
# EU: https://llm-gateway.eu.assemblyai.com/v1/chat/completions
# ASSEMBLYAI_LLM_URL=

ASSEMBLYAI_MODEL_DEFAULT=claude-sonnet-4-5-20250929
ASSEMBLYAI_MODEL_CRITICAL=claude-opus-4-6

# Scans: optional JSON "cookies" array (New scan → sign-in) is sent in the POST body only;
# it is not stored in env. Treat exported session cookies as secrets.

# Local development: path to Chrome/Chromium binary for accessibility scans
# macOS example:
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Local macOS/Windows only — leave unset on Vercel/Linux (uses bundled serverless Chromium).
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# PUPPETEER_EXECUTABLE_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
PUPPETEER_EXECUTABLE_PATH=

# --- Jira Cloud (optional): “Report to Jira” creates issues via REST API ---
# If unset, the app logs a mock response instead of calling Jira.
# JIRA_HOST=your-domain.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=from https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_PROJECT_KEY=PROJ
# JIRA_ISSUE_TYPE=Task
#
# --- Manual test plan (Testing Scenarios → Jira): one Test issue, multiple cases ---
# Issue type name in your Jira project (often "Test" for Xray / Zephyr Squad)
# JIRA_TEST_ISSUE_TYPE=Test
# Description layout: generic | xray | zephyr (can be overridden per request in UI)
# JIRA_TEST_TOOL=generic
# Optional JSON merged into Jira create-issue fields (custom field ids for your site), e.g. Xray test type:
# JIRA_TEST_PLAN_EXTRA_FIELDS={"customfield_12345":{"value":"Manual"}}

# --- Authentication (NextAuth v5 + GitHub OAuth) ---
# All routes except `/` and `/api/auth/*` require sign-in. The DB-backed
# multi-page scans, server reports, and dashboard stats also require a session.

# Random 32+ byte secret (generate with `openssl rand -base64 32`).
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32

# GitHub OAuth app credentials.
# Create at: https://github.com/settings/developers (New OAuth App)
#   Homepage URL:        http://localhost:3000  (or your deployed URL)
#   Authorization URL:   http://localhost:3000/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# Optional: set when deployed behind a proxy / non-default origin so callback URLs are correct.
# Example for production: https://a11yagent.vercel.app
# AUTH_URL=

# --- SQLite Database (auto-created on first authenticated request) ---
# DB_PATH=./data/a11yagent.db

# --- Upstash Redis (per-IP rate limiting on /api/scan, /api/ai-*, /api/chat) ---
# Create a free DB at https://console.upstash.com → copy the REST URL + REST Token.
# Tiers: scan 10/h, ai 50/h, chat 30/h (sliding window, per IP).
# Local dev: leave both blank — rate limiting is skipped and a single warning logs.
#
# These same credentials also power the URL-keyed scan store (Fix 5)
# and the 10-minute scan cache (Fix 6), which back:
#   - /api/scan         → persists each scan body for 30 days (key: scan:id:{id})
#   - /api/scan?cache   → 10 min response cache (key: scan:cache:{urlHash}:{optsHash});
#                         pass `?force=true` (or { force: true }) to bypass.
#                         Cache reads are bounded to 500 ms so a slow Upstash
#                         hop never blocks a real scan.
#   - /api/scan-diff    → "vs. last scan: +N new, -M resolved" UI chip
# No additional env vars are required for the scan store, cache, or diff.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- IBM Equal Access (accessibility-checker) ---
# Runs alongside axe-core in the same Puppeteer page on /api/scan.
# Issues flagged by both tools collapse to a single finding with severity
# bumped one rung. Set to `false` to skip IBM entirely (e.g. environments
# where chromedriver is unavailable, or to keep scan latency minimal).
# IBM_CHECKER_ENABLED=true

# --- Fix 8: GitHub Actions CI scan bypass ---
# When the `.github/workflows/a11y-check.yml` workflow runs, it has no GitHub
# OAuth flow, so middleware.ts would normally redirect /api/scan to /signin.
# To allow the CI runner through, set this env var on the running server to
# the same opaque secret stored as the `A11Y_CI_TOKEN` GitHub repo secret.
# When unset (production), the bypass cannot fire even if a caller sends the
# header. Generate with: `openssl rand -hex 32`.
# A11Y_CI_TOKEN=